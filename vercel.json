{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/pages/index.html" },
    { "source": "/welcome", "destination": "/pages/welcome.html" },
    { "source": "/about", "destination": "/pages/about.html" },
    { "source": "/college", "destination": "/pages/college.html" },
    { "source": "/gallery", "destination": "/pages/gallery.html" },
    { "source": "/map", "destination": "/pages/map.html" },
    { "source": "/games", "destination": "/pages/games.html" },
    { "source": "/guide", "destination": "/pages/guide.html" }
  ]
}
